<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.coworktil.autopush</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/dawnnguyen/VSCProject/Cowork-TIL/scripts/auto-push.sh</string>
    </array>

    <!-- Chạy lúc 9:30 AM mỗi ngày (sau khi Cowork scheduled task viết bài lúc 9AM) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/dawnnguyen/VSCProject/Cowork-TIL/scripts/auto-push.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/dawnnguyen/VSCProject/Cowork-TIL/scripts/auto-push.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
